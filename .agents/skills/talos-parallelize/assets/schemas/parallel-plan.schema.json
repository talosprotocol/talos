{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "goal": {
      "type": "string"
    },
    "stages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "index": {
            "type": "integer",
            "minimum": 1
          },
          "mode": {
            "type": "string",
            "enum": [
              "serial",
              "parallel"
            ]
          },
          "tasks": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "blocked_candidates": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "task_id": {
                  "type": "string"
                },
                "blocked_by": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "task_id": {
                        "type": "string"
                      },
                      "reasons": {
                        "type": "array",
                        "items": {
                          "type": "string"
                        }
                      }
                    },
                    "required": [
                      "task_id",
                      "reasons"
                    ]
                  }
                }
              },
              "required": [
                "task_id",
                "blocked_by"
              ]
            }
          }
        },
        "required": [
          "index",
          "mode",
          "tasks",
          "blocked_candidates"
        ]
      }
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string"
          },
          "summary": {
            "type": "string"
          },
          "depends_on": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "writes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "generated_outputs": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "runtime_resources": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "verify": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "done": {
            "type": "string"
          },
          "serial_only": {
            "type": "boolean"
          },
          "owner_hint": {
            "type": "string"
          },
          "exclusive_boundaries": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "suggested_skill": {
            "type": "string"
          },
          "conflicts": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "task_id": {
                  "type": "string"
                },
                "reasons": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "required": [
                "task_id",
                "reasons"
              ]
            }
          }
        },
        "required": [
          "id",
          "summary",
          "depends_on",
          "writes",
          "generated_outputs",
          "runtime_resources",
          "verify",
          "done",
          "serial_only",
          "owner_hint",
          "exclusive_boundaries",
          "notes",
          "suggested_skill",
          "conflicts"
        ]
      }
    },
    "monitoring": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "required": [
    "goal",
    "stages",
    "tasks",
    "monitoring"
  ]
}
