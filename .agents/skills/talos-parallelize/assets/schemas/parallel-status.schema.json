{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "tasks": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "state": {
            "type": "string",
            "enum": [
              "pending",
              "ready",
              "running",
              "paused",
              "blocked",
              "done",
              "failed"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    }
  },
  "required": [
    "tasks"
  ]
}
